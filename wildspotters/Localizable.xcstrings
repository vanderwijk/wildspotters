    "register.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Spot them all! Create a free account to get started. We'll email you an activation link. Open it on any device, then sign in here with your password."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spot ze allemaal! Maak een gratis account aan om mee te doen. We sturen je een activatielink per e-mail. Open die op elk apparaat en log daarna hier in met je wachtwoord."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spotte sie alle! Erstelle ein kostenloses Konto, um loszulegen. Wir senden dir einen Aktivierungslink per E-Mail. Öffne ihn auf einem beliebigen Gerät und melde dich dann hier mit deinem Passwort an."
          }
        }
      }
    },
